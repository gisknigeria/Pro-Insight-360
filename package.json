{
  "name": "pro-insight-360",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "postinstall": "npx prisma generate --schema=apps/api/prisma/schema.prisma",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build:web": "pnpm --filter web build",
    "build:api": "npx prisma migrate deploy --schema=apps/api/prisma/schema.prisma && pnpm --filter api build",
    "test:web": "pnpm --filter web test",
    "test:api": "pnpm --filter api test",
    "lint": "pnpm -r lint"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "prisma": "^7.8.0"
  }
}

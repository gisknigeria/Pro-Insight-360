{
  "name": "pro-insight-360",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10",
  "scripts": {
    "postinstall": "npx prisma generate --schema=apps/api/prisma/schema.prisma",
    "dev:web": "npm -w web run dev",
    "dev:api": "npm -w api run dev",
    "build:api": "npm -w api run build",
    "build:web": "npm -w web run build",
    "migrate:deploy": "npx prisma migrate deploy --schema=apps/api/prisma/schema.prisma",
    "test:web": "npm -w web run test",
    "test:api": "npm -w api run test",
    "lint": "npm workspaces run lint"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "prisma": "^7.8.0"
  },
  "dependencies": {
    "@types/node": "^25.9.2"
  }
}

# Database - Neon PostgreSQL
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT
JWT_SECRET="your-jwt-secret-min-16-chars"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET="your-refresh-secret-min-16-chars"
JWT_REFRESH_EXPIRES_IN="7d"

# Upstash Redis
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Backblaze B2 Storage (S3-compatible, free 10GB — backblaze.com)
B2_KEY_ID="your-b2-key-id"
B2_APPLICATION_KEY="your-b2-application-key"
B2_BUCKET_NAME="pro-insight-360-files"
B2_BUCKET_ID="your-b2-bucket-id"
B2_ENDPOINT="https://s3.us-west-004.backblazeb2.com"

# AI Providers
GEMINI_API_KEY="your-gemini-api-key"
GROQ_API_KEY="your-groq-api-key"

# Email - Brevo (free 300 emails/day — brevo.com)
BREVO_API_KEY="your-brevo-api-key"
BREVO_FROM_EMAIL="noreply@your-domain.com"
BREVO_FROM_NAME="Pro-Insight 360"

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

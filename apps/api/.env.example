# Database - Neon PostgreSQL
# Pooled connection (for runtime queries via Prisma Client)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
# Direct connection (for Prisma migrations - replace with your direct URL from Neon dashboard)
DIRECT_DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# JWT
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET="change-this-refresh-secret-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Upstash Redis
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# Backblaze B2 Storage (S3-compatible)
B2_KEY_ID="your-backblaze-key-id"
B2_APPLICATION_KEY="your-backblaze-application-key"
B2_BUCKET_NAME="your-bucket-name"
B2_BUCKET_ID="your-bucket-id"
B2_ENDPOINT="https://s3.us-east-005.backblazeb2.com"

# AI Providers
GEMINI_API_KEY="your-gemini-api-key"
GROQ_API_KEY="your-groq-api-key"

# Email - Brevo
BREVO_API_KEY="your-brevo-api-key"
BREVO_FROM_EMAIL="noreply@your-domain.com"
BREVO_FROM_NAME="Pro-Insight 360"

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"